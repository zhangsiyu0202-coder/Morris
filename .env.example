# --- App-facing config (consumed by web / agent / functions / scripts) ---
# Appwrite
APPWRITE_ENDPOINT=http://localhost:8080/v1
APPWRITE_PROJECT_ID=changeme
APPWRITE_API_KEY=changeme
NEXT_PUBLIC_APPWRITE_ENDPOINT=http://localhost:8080/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=changeme
# Appwrite Function id that issues LiveKit room tokens (web calls it from the browser)
NEXT_PUBLIC_ISSUE_TOKEN_FUNCTION_ID=issueLivekitToken
# Base URL the researcher web app is served from. Used to build Appwrite email
# links (email verification, password recovery). No trailing slash.
APP_URL=http://localhost:3000
# Optional: Appwrite Account $id for seed scripts; see docs/dev/local-researcher-account.md
# MERISM_OWNER_USER_ID=your-account-id

# LiveKit
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret-change-me-min-32-chars-long
# Room composite egress staging (S3-compatible). When unset, video recording is skipped.
# LIVEKIT_EGRESS_S3_BUCKET=merism-interview-recordings
# LIVEKIT_EGRESS_S3_ACCESS_KEY=changeme
# LIVEKIT_EGRESS_S3_SECRET=changeme
# LIVEKIT_EGRESS_S3_REGION=us-east-1
# LIVEKIT_EGRESS_S3_ENDPOINT=
# Local egress (docker compose livekit-egress mounts infra/docker/egress -> /out)
# EGRESS_OUTPUT_DIR=/out
# EGRESS_LOCAL_MOUNT=/absolute/path/to/MerismV2/infra/docker/egress

# LLM provider (all LLM calls)
DEEPSEEK_API_KEY=changeme
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ASR / TTS providers (Qwen via DashScope OpenAI-compatible gateway)
QWEN_API_KEY=changeme
# DASHSCOPE_API_KEY=changeme            # alias accepted in place of QWEN_API_KEY
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_ASR_MODEL=paraformer-realtime-v2
# QWEN_TTS_MODEL=cosyvoice-v1
# QWEN_TTS_VOICE=longxiaochun
# QWEN_SPEECH_BACKEND=openai            # openai (default) | dashscope (reserved)
# QWEN_LANGUAGE=zh
STT_PROVIDER_KEY=changeme
TTS_PROVIDER_KEY=changeme

# Visual analysis (post-session). PostHog-style: Gemini Files API + per-segment
# start_offset/end_offset + DeepSeek consolidation. Off by default; turn on by
# setting GEMINI_VISUAL_ANALYSIS_ENABLED=true and providing a base URL + key.
# GEMINI_VISUAL_ANALYSIS_ENABLED=false
# GEMINI_API_BASE_URL=https://merism-gemini-proxy.<your-cf-account>.workers.dev/
# GEMINI_API_KEY=changeme
# GEMINI_VISUAL_MODEL=gemini-2.5-flash-lite
# GEMINI_VIDEO_MAX_BYTES=2147483648         # default 2 GB
# GEMINI_UPLOAD_MAX_WAIT_SEC=300
# GEMINI_SEGMENT_PARALLELISM=4
# GEMINI_MIN_SUCCESS_RATIO=0.5

# --- Appwrite container internals (override for non-dev) ---
_APP_ENV=development
_APP_OPENSSL_KEY_V1=dev-secret-key-change-me
_APP_DB_ROOT_PASS=rootsecret
_APP_DB_USER=appwrite
_APP_DB_PASS=appwrite
_APP_DB_SCHEMA=appwrite
_APP_EXECUTOR_SECRET=dev-executor-secret

# --- Workspaces & Billing (ADR 0006) ---
# Stripe (server-only; never logged — maskSecret). Live values stay in the deploy env.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PLUS=
STRIPE_PRICE_PRO=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
